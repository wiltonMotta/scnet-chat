#!/bin/bash
# SCNet Chat 跨平台启动脚本 (Unix/macOS)
# 自动检测并使用正确的 Python 解释器

set -e

# 获取脚本所在目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCNET_PY="${SCRIPT_DIR}/scnet.py"

# 检查 python3 是否存在
if command -v python3 &> /dev/null; then
    PYTHON_CMD="python3"
elif command -v python &> /dev/null; then
    # 检查 python 版本是否是 3.x
    PYTHON_VERSION=$(python --version 2>&1 | grep -oE '[0-9]+' | head -1)
    if [ "$PYTHON_VERSION" = "3" ]; then
        PYTHON_CMD="python"
    else
        echo "错误: 需要 Python 3，但找到的 python 是 Python $PYTHON_VERSION" >&2
        echo "请安装 Python 3 并确保 python3 命令可用" >&2
        exit 1
    fi
else
    echo "错误: 未找到 Python 解释器，请安装 Python 3" >&2
    exit 1
fi

# 执行 scnet.py
exec "$PYTHON_CMD" "$SCNET_PY" "$@"
